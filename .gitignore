# ── 환경 / 시크릿 ─────────────────────────────────────────
.env
.token

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── 가상환경 ───────────────────────────────────────────────
venv/
env/
.venv/

# ── 생성 출력물 (자동 생성, 재생성 가능) ──────────────────
output/

# ── 다운로드 폰트 (setup_fonts.py로 재설치 가능) ──────────
fonts/

# ── 배경 이미지 (사용자 제공 에셋, 바이너리) ──────────────
assets/

